{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "baseUrl": ".",
    "paths": {
      "utility": [
        "utility/index"
      ],
      "pageobjects_uiPlayground": [
        "pageobjects_uiPlayground/index"
      ]
    },
    "types": [
      "node",
      "@playwright/test"
    ],
    "esModuleInterop": true,
    "strict": false,
    "skipLibCheck": true
  },
  "include": [
    "**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
